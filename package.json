{
  "name": "obs-church-studio",
  "private": true,
  "version": "0.40.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "sync:local-llm-model": "node scripts/sync-local-llm-model.cjs",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/sync-version.cjs",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/sync-version.cjs",
    "version:major": "npm version major --no-git-tag-version && node scripts/sync-version.cjs",
    "release:patch": "npm run version:patch && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push",
    "release:minor": "npm run version:minor && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push",
    "release:major": "npm run version:major && git add . && git commit -m \"v$(node -p \"require('./package.json').version\")\" && git push"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-http": "^2.5.7",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.0",
    "idb": "^8.0.3",
    "konva": "^10.2.0",
    "lucide-react": "^0.577.0",
    "nanoid": "^5.1.6",
    "obs-websocket-js": "^5.0.7",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-konva": "^19.2.2",
    "react-router-dom": "^7.13.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@types/react-router-dom": "^5.3.3",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}
