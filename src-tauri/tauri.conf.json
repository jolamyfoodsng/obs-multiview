{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OBS Church Studio",
  "version": "0.35.0",
  "identifier": "com.obschurchstudio.app",
  "build": {
    "beforeDevCommand": "npm run sync:local-llm-model && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run sync:local-llm-model && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OBS Church Studio",
        "width": 1280,
        "height": 820,
        "minWidth": 800,
        "minHeight": 600,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self' asset: data: blob:; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; img-src 'self' asset: data: blob: http://127.0.0.1:* http://localhost:* https:; font-src 'self' data: https://fonts.gstatic.com; connect-src 'self' http://127.0.0.1:* http://localhost:* ws://127.0.0.1:* ws://localhost:* https://api.github.com https://github.com https://obs-multiview-backend-api.fly.dev https://*.r2.cloudflarestorage.com https://*.r2.dev;"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "resources": [
      "../dist/bible-overlay-fullscreen.html",
      "../dist/bible-overlay-lower-third.html",
      "../dist/bible-overlay-bg.html",
      "../dist/bible-kjv.json",
      "../dist/lower-third-overlay.html",
      "../dist/pre-service-countdown.html",
      "../dist/pre-service-media.html",
      "../dist/dock.html",
      "../dist/assets/**/*",
      "../dist/fonts/**/*",
      "resources/models/llm/**/*"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFBQzlGM0YzM0NBQzgxREIKUldUYmdhdzg4L1BKcWhtcTlmVFZpUjV3ZzBvT1ZVV2lKc29CS0VYaXJUd2s4SkErR09NS0dYTDcK",
      "endpoints": [
        "https://github.com/jolamyfoodsng/obs-multiview/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
