.pre-service-auto {
  display: flex;
  height: 100%;
  min-height: 0;
  background: var(--bg-dark);
  color: var(--text-primary);
}

.pre-service-left {
  width: 380px;
  min-width: 320px;
  max-width: 420px;
  border-right: 1px solid var(--border);
  background: var(--surface-dark);
  display: flex;
  flex-direction: column;
  gap: 12px;
  padding: 14px;
  overflow-y: auto;
}

.pre-service-right {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  background: var(--bg-dark);
}

.pre-service-intro h2 {
  margin: 0;
  font-size: 20px;
  line-height: 1.2;
  font-weight: 800;
}

.pre-service-intro p {
  margin-top: 6px;
  color: var(--text-secondary);
  font-size: 12px;
  line-height: 1.45;
}

.pre-service-primary-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.ps-btn-run,
.ps-btn-preview {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  min-height: 42px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--surface-hover);
  color: var(--text-primary);
  cursor: pointer;
  font-size: 12px;
  font-weight: 700;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}

.ps-btn-run {
  background: var(--primary);
  border-color: var(--primary);
  color: #101010;
}

.ps-btn-run:hover:not(:disabled) {
  background: var(--primary-hover);
  border-color: var(--primary-hover);
}

.ps-btn-preview {
  background: transparent;
  color: var(--text-secondary);
}

.ps-btn-preview:hover:not(:disabled) {
  color: var(--text-primary);
  border-color: var(--text-muted);
  background: var(--surface-hover);
}

.pre-service-auto button:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.pre-service-status-card {
  border: 1px solid var(--border-primary);
  background: rgba(var(--primary-rgb), 0.06);
  border-radius: 8px;
  padding: 12px;
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.pre-service-status-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.pre-service-status-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--primary);
}

.pre-service-runtime-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  font-size: 9px;
  font-weight: 700;
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 3px 8px;
  color: var(--text-secondary);
  background: var(--surface-dark);
}

.pre-service-runtime-chip.is-running {
  border-color: rgba(var(--success-rgb), 0.38);
  color: var(--success);
}

.pre-service-runtime-chip.is-paused {
  border-color: rgba(249, 168, 37, 0.38);
  color: var(--warning);
}

.pre-service-runtime-chip.is-finished {
  border-color: rgba(var(--success-rgb), 0.38);
  color: var(--success);
}

.pre-service-runtime-chip.is-idle {
  color: var(--text-muted);
}

.pre-service-status-title {
  font-size: 15px;
  font-weight: 700;
  color: var(--text-primary);
}

.pre-service-remaining {
  font-size: 32px;
  line-height: 1;
  font-weight: 800;
  letter-spacing: -0.03em;
  font-variant-numeric: tabular-nums;
}

.pre-service-progress-track {
  height: 8px;
  border-radius: 999px;
  background: rgba(255, 255, 255, 0.08);
  overflow: hidden;
}

.pre-service-progress-fill {
  height: 100%;
  background: var(--primary);
  transition: width 0.25s linear;
}

.pre-service-next-row {
  display: flex;
  align-items: center;
  gap: 6px;
  font-size: 12px;
  color: var(--text-secondary);
  border-top: 1px solid var(--border);
  padding-top: 10px;
}

.truncate {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.pre-service-controls-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 8px;
}

.pre-service-controls-row button,
.pre-service-toolbar-actions button,
.pre-service-modal-footer button,
.pre-service-step-actions button {
  border: 1px solid var(--border);
  background: var(--surface-hover);
  color: var(--text-primary);
  border-radius: 6px;
  padding: 8px 10px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: background 0.15s, border-color 0.15s, color 0.15s;
}

.pre-service-controls-row button:hover:not(:disabled),
.pre-service-toolbar-actions button:hover:not(:disabled),
.pre-service-modal-footer button:hover:not(:disabled),
.pre-service-step-actions button:hover:not(:disabled) {
  border-color: var(--text-muted);
  background: var(--surface-raised);
}

.pre-service-controls-row button .material-icons,
.pre-service-toolbar-actions button .material-icons,
.pre-service-step-actions button .material-icons,
.pre-service-modal-footer button .material-icons,
.pre-service-primary-actions button .material-icons {
  font-size: 16px;
}

.pre-service-toolbar-actions button.ghost,
.pre-service-modal-footer button.ghost {
  background: transparent;
  color: var(--text-secondary);
}

.pre-service-settings {
  display: flex;
  flex-direction: column;
  gap: 8px;
  border-top: 1px solid var(--border);
  padding-top: 10px;
}

.pre-service-settings label {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8px;
  color: var(--text-secondary);
  font-size: 12px;
}

.pre-service-settings label span {
  min-width: 0;
}

.pre-service-settings .stacked {
  align-items: flex-start;
  flex-direction: column;
}

.pre-service-settings input,
.pre-service-settings select,
.pre-service-step-controls input,
.pre-service-step-controls select,
.pre-service-step-title-row input,
.pre-service-modal-form input,
.pre-service-modal-form select {
  width: 100%;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg-dark);
  color: var(--text-primary);
  padding: 7px 9px;
  font-size: 12px;
  font-family: inherit;
}

.pre-service-settings input:focus,
.pre-service-settings select:focus,
.pre-service-step-controls input:focus,
.pre-service-step-controls select:focus,
.pre-service-step-title-row input:focus,
.pre-service-modal-form input:focus,
.pre-service-modal-form select:focus {
  outline: none;
  border-color: var(--primary);
}

.pre-service-settings input[type="checkbox"] {
  width: 16px;
  height: 16px;
  accent-color: var(--primary);
}

.pre-service-error {
  border: 1px solid rgba(231, 72, 86, 0.35);
  background: var(--error-bg);
  color: #f19ba0;
  border-radius: 6px;
  padding: 8px;
  font-size: 12px;
}

.pre-service-warning {
  border: 1px solid rgba(249, 168, 37, 0.32);
  background: rgba(249, 168, 37, 0.08);
  color: #f9d27a;
  border-radius: 6px;
  padding: 8px;
  font-size: 12px;
}

.pre-service-toolbar {
  border-bottom: 1px solid var(--border);
  padding: 12px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.pre-service-toolbar-left {
  display: flex;
  align-items: center;
  gap: 10px;
}

.pre-service-toolbar-left h3 {
  margin: 0;
  font-size: 16px;
  font-weight: 700;
}

.pre-service-toolbar-left span {
  font-size: 11px;
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 2px 8px;
}

.pre-service-toolbar-actions {
  display: flex;
  align-items: center;
  gap: 8px;
}

.pre-service-steps-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  padding: 12px;
}

.pre-service-steps-list {
  display: flex;
  flex-direction: column;
  gap: 10px;
}

.pre-service-step-card {
  display: grid;
  grid-template-columns: auto 1fr auto;
  gap: 10px;
  border: 1px solid var(--border);
  border-radius: 8px;
  background: var(--surface-dark);
  padding: 10px;
}

.pre-service-step-card.is-active {
  border-color: var(--border-primary);
  box-shadow: 0 0 0 1px rgba(var(--primary-rgb), 0.24) inset;
}

.pre-service-step-index {
  width: 24px;
  height: 24px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--surface-hover);
  color: var(--text-secondary);
  font-size: 11px;
  font-weight: 700;
}

.pre-service-step-main {
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8px;
}

.pre-service-step-title-row {
  display: grid;
  grid-template-columns: auto 1fr auto;
  align-items: center;
  gap: 8px;
}

.pre-service-step-title-row input {
  min-width: 0;
}

.pre-service-step-title-row .material-icons {
  font-size: 18px;
  color: var(--primary);
}

.pre-service-step-type {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--text-secondary);
  border: 1px solid var(--border);
  border-radius: 999px;
  padding: 2px 8px;
}

.pre-service-step-controls {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.pre-service-step-controls label,
.pre-service-modal-form label {
  display: flex;
  flex-direction: column;
  gap: 4px;
}

.pre-service-step-controls label > span,
.pre-service-modal-form label > span {
  font-size: 10px;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-secondary);
  font-weight: 700;
}

.inline-row {
  display: grid;
  grid-template-columns: 1fr 80px;
  gap: 6px;
}

.pre-service-step-actions {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.pre-service-empty {
  border: 1px dashed var(--border);
  border-radius: 8px;
  color: var(--text-secondary);
  padding: 24px;
  text-align: center;
  font-size: 13px;
}

.pre-service-modal-backdrop {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.62);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 120;
  padding: 22px;
}

.pre-service-modal {
  width: min(980px, 100%);
  max-height: min(92dvh, 820px);
  border-radius: 14px;
  border: 1px solid var(--border);
  background: var(--surface-raised);
  overflow: hidden;
  display: flex;
  flex-direction: column;
  box-shadow: 0 28px 70px rgba(0, 0, 0, 0.45);
}

.pre-service-modal-body {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  background: var(--bg-dark);
}

.pre-service-modal-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 14px;
  padding: 16px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--surface-dark);
}

.pre-service-modal-head-content {
  min-width: 0;
}

.pre-service-modal-head h4 {
  margin: 0;
  font-size: 24px;
  line-height: 1.2;
  font-weight: 800;
  letter-spacing: -0.01em;
  color: var(--text-primary);
}

.pre-service-modal-head p {
  margin: 6px 0 0;
  font-size: 12px;
  color: var(--text-secondary);
  line-height: 1.45;
}

.pre-service-modal-head button {
  width: 34px;
  height: 34px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--surface-hover);
  color: var(--text-secondary);
  cursor: pointer;
  transition: color 0.15s, border-color 0.15s, background 0.15s;
}

.pre-service-modal-head button:hover {
  color: var(--text-primary);
  border-color: var(--text-muted);
  background: var(--surface-raised);
}

.pre-service-modal-head button .material-icons {
  font-size: 18px;
}

.pre-service-step-type-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12px;
  padding: 16px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--bg-dark);
}

.pre-service-step-type-grid--picker {
  border-bottom: none;
  padding: 18px;
}

.type-card {
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  gap: 10px;
  min-height: 170px;
  border: 1px solid var(--border);
  border-radius: 12px;
  background: var(--surface-dark);
  color: var(--text-secondary);
  cursor: pointer;
  font-size: 12px;
  font-weight: 600;
  padding: 14px;
  text-align: left;
  transition: border-color 0.15s, background 0.15s, transform 0.15s;
}

.type-card:hover {
  border-color: var(--text-muted);
  background: var(--surface-hover);
  transform: translateY(-1px);
}

.type-card:focus-visible {
  outline: none;
  border-color: var(--primary);
  box-shadow: 0 0 0 2px rgba(var(--primary-rgb), 0.22);
}

.type-card.is-selected {
  border-color: var(--border-primary);
  color: var(--text-primary);
  background: rgba(var(--primary-rgb), 0.08);
  box-shadow: 0 0 0 1px rgba(var(--primary-rgb), 0.18) inset;
}

.type-card.is-disabled {
  opacity: 0.38;
  cursor: not-allowed;
  pointer-events: none;
}

.type-card.is-disabled:hover {
  border-color: var(--border);
  background: var(--surface-dark);
  transform: none;
}

.type-card-icon.is-disabled {
  background: var(--surface-hover);
  color: var(--text-muted);
}

.type-card-check {
  position: absolute;
  right: 10px;
  top: 10px;
  width: 18px;
  height: 18px;
  border-radius: 999px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: var(--primary);
  color: #121212;
}

.type-card-check .material-icons {
  font-size: 12px;
  font-weight: 700;
}

.type-card-icon {
  width: 44px;
  height: 44px;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: rgba(var(--primary-rgb), 0.12);
  color: var(--primary);
}

.type-card-icon .material-icons {
  font-size: 24px;
}

.type-card-body {
  display: flex;
  flex-direction: column;
  gap: 6px;
  min-width: 0;
}

.type-card-title {
  font-size: 17px;
  line-height: 1.2;
  font-weight: 700;
  color: var(--text-primary);
}

.type-card-desc {
  font-size: 12px;
  line-height: 1.45;
  color: var(--text-secondary);
}

.pre-service-modal-form-wrap {
  padding: 16px 18px;
  overflow-y: auto;
  display: flex;
  flex-direction: column;
  gap: 10px;
  background: var(--bg-dark);
}

.pre-service-modal-form-wrap--configure {
  min-height: 0;
}

.pre-service-modal-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10px;
}

.pre-service-modal-section-head h5 {
  margin: 0;
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--text-secondary);
}

.pre-service-modal-section-head span {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.05em;
  text-transform: uppercase;
  color: var(--primary);
  border: 1px solid var(--border-primary);
  border-radius: 999px;
  padding: 3px 8px;
}

.pre-service-modal-form {
  display: flex;
  flex-direction: column;
  gap: 10px;
  padding: 0;
}

.split-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 8px;
}

.pre-service-modal-footer {
  display: flex;
  justify-content: flex-end;
  gap: 8px;
  padding: 14px 18px;
  border-top: 1px solid var(--border);
  background: var(--surface-dark);
}

.pre-service-modal-footer button:last-child {
  background: var(--primary);
  border-color: var(--primary);
  color: #121212;
  font-weight: 700;
  box-shadow: 0 0 0 1px rgba(var(--primary-rgb), 0.22) inset;
}

.pre-service-modal-footer button:last-child:hover:not(:disabled) {
  background: var(--primary-hover);
  border-color: var(--primary-hover);
}

@media (max-width: 1260px) {
  .pre-service-left {
    width: 100%;
    max-width: none;
    min-width: 0;
    border-right: none;
    border-bottom: 1px solid var(--border);
  }

  .pre-service-step-card {
    grid-template-columns: 1fr;
  }

  .pre-service-step-actions {
    flex-direction: row;
    justify-content: flex-end;
  }
}

@media (max-width: 900px) {
  .pre-service-modal {
    border-radius: 10px;
  }

  .pre-service-modal-head {
    padding: 12px;
  }

  .pre-service-modal-head h4 {
    font-size: 20px;
  }

  .pre-service-toolbar {
    flex-direction: column;
    align-items: stretch;
  }

  .pre-service-toolbar-actions {
    width: 100%;
  }

  .pre-service-toolbar-actions button {
    flex: 1;
  }

  .pre-service-step-controls {
    grid-template-columns: 1fr;
  }

  .pre-service-step-type-grid {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    padding: 12px;
    gap: 8px;
  }

  .pre-service-step-type-grid--picker {
    padding: 12px;
  }

  .type-card {
    min-height: 110px;
    padding: 12px;
  }

  .type-card-title {
    font-size: 15px;
  }

  .pre-service-modal-form-wrap {
    padding: 12px;
  }

  .split-grid {
    grid-template-columns: 1fr;
  }
}

@media (max-height: 860px) {
  .pre-service-intro h2 {
    font-size: 17px;
  }

  .pre-service-remaining {
    font-size: 24px;
  }

  .pre-service-primary-actions {
    grid-template-columns: 1fr;
  }

  .ps-btn-run,
  .ps-btn-preview {
    min-height: 36px;
    font-size: 11px;
  }

  .pre-service-toolbar {
    padding: 8px 10px;
  }

  .pre-service-toolbar-left h3 {
    font-size: 14px;
  }

  .pre-service-steps-scroll {
    padding: 8px;
  }

  .pre-service-step-card {
    padding: 8px;
  }

  .pre-service-modal {
    max-height: min(95dvh, 700px);
  }
}

@media (max-height: 760px) {
  .pre-service-auto {
    font-size: 11px;
  }

  .pre-service-left {
    padding: 10px;
    gap: 8px;
  }

  .pre-service-intro h2 {
    font-size: 15px;
  }

  .pre-service-intro p {
    font-size: 11px;
  }

  .ps-btn-run,
  .ps-btn-preview {
    min-height: 30px;
    font-size: 10px;
  }

  .pre-service-status-title {
    font-size: 13px;
  }

  .pre-service-remaining {
    font-size: 20px;
  }

  .pre-service-toolbar {
    padding: 6px 8px;
  }

  .pre-service-toolbar-left h3 {
    font-size: 13px;
  }

  .pre-service-toolbar-actions button,
  .pre-service-controls-row button {
    padding: 6px 8px;
    font-size: 10px;
  }

  .pre-service-step-card {
    padding: 6px;
  }

  .pre-service-step-title-row .material-icons {
    font-size: 16px;
  }

  .pre-service-step-type {
    font-size: 9px;
  }

  .pre-service-step-controls label > span,
  .pre-service-modal-form label > span {
    font-size: 9px;
  }

  .pre-service-settings input,
  .pre-service-settings select,
  .pre-service-step-controls input,
  .pre-service-step-controls select,
  .pre-service-step-title-row input,
  .pre-service-modal-form input,
  .pre-service-modal-form select {
    font-size: 11px;
    padding: 6px 8px;
  }

  .pre-service-modal-head h4 {
    font-size: 18px;
  }
}

@media (max-height: 750px) {
  .pre-service-auto {
    zoom: 0.7;
  }

  .pre-service-modal {
    max-height: min(96dvh, 680px);
  }
}

/* ───────────────────────────────────────────────────────
   Configure-stage forms (per step type)
   ─────────────────────────────────────────────────────── */

/* Shared toolbar (search + pills) used by Video, Image, Audio */
.cfg-media-picker {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1;
  min-height: 0;
}

.cfg-media-picker__toolbar {
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 12px;
  padding: 12px 18px;
  border-bottom: 1px solid var(--border);
  background: var(--surface-dark);
}

.cfg-search-wrap {
  position: relative;
  flex: 1 1 220px;
  min-width: 180px;
}

.cfg-search-icon {
  position: absolute;
  left: 10px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 18px;
  color: var(--text-muted);
  pointer-events: none;
}

.cfg-search-input {
  width: 100%;
  padding: 8px 12px 8px 34px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg-dark);
  color: var(--text-primary);
  font-size: 13px;
  outline: none;
  transition: border-color 0.15s;
}

.cfg-search-input:focus {
  border-color: var(--primary);
}

.cfg-search-input::placeholder {
  color: var(--text-muted);
}

.cfg-filter-pills {
  display: flex;
  gap: 6px;
  flex-wrap: wrap;
}

.cfg-pill {
  padding: 5px 12px;
  border-radius: 999px;
  font-size: 11px;
  font-weight: 600;
  border: 1px solid var(--border);
  background: var(--surface-dark);
  color: var(--text-secondary);
  cursor: pointer;
  white-space: nowrap;
  transition: all 0.15s;
}

.cfg-pill:hover {
  border-color: var(--text-muted);
  color: var(--text-primary);
}

.cfg-pill.is-active {
  background: var(--primary);
  border-color: var(--primary);
  color: #121212;
  font-weight: 700;
}

/* ---------- Media grid (video + image cards) ---------- */
.cfg-media-grid {
  flex: 1;
  overflow-y: auto;
  padding: 16px 18px;
  display: grid;
  gap: 12px;
  align-content: start;
  background: var(--bg-dark);
}

.cfg-media-grid--video {
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
}

.cfg-media-grid--image {
  grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
}

.cfg-media-card {
  position: relative;
  border-radius: 10px;
  border: 2px solid var(--border);
  overflow: hidden;
  cursor: pointer;
  background: var(--surface-dark);
  aspect-ratio: 16/9;
  transition: border-color 0.15s, box-shadow 0.15s;
}

.cfg-media-card:hover {
  border-color: var(--text-muted);
}

.cfg-media-card.is-selected {
  border-color: var(--primary);
  box-shadow: 0 0 12px rgba(var(--primary-rgb), 0.18);
}

.cfg-media-card__thumb {
  position: absolute;
  inset: 0;
  display: flex;
  align-items: center;
  justify-content: center;
}

.cfg-media-card__thumb img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.7;
  transition: opacity 0.15s;
}

.cfg-media-card:hover .cfg-media-card__thumb img {
  opacity: 1;
}

.cfg-media-card__placeholder {
  font-size: 36px;
  color: var(--text-muted);
}

.cfg-media-card__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, transparent 60%);
  pointer-events: none;
}

.cfg-media-card__check {
  position: absolute;
  top: 6px;
  right: 6px;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--primary);
  color: #121212;
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 2;
  box-shadow: 0 1px 4px rgba(0,0,0,0.35);
}

.cfg-media-card__check .material-icons {
  font-size: 14px;
  font-weight: 700;
}

.cfg-media-card__info {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 8px 10px;
  z-index: 1;
}

.cfg-media-card__name {
  font-size: 11px;
  font-weight: 700;
  color: #fff;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

/* ---------- Selection bar (bottom of media/audio pickers) ---------- */
.cfg-selection-bar {
  padding: 12px 18px;
  border-top: 1px solid var(--border);
  background: var(--surface-dark);
}

.cfg-selection-bar__count {
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 13px;
  font-weight: 500;
  color: var(--text-primary);
}

.cfg-selection-bar__hint {
  color: var(--text-secondary);
  font-size: 13px;
}

.cfg-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  border-radius: 50%;
  background: var(--primary);
  color: #121212;
  font-size: 11px;
  font-weight: 700;
}

/* ---------- Empty state ---------- */
.cfg-empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10px;
  padding: 48px 16px;
  color: var(--text-muted);
  grid-column: 1 / -1;
}

.cfg-empty-state .material-icons {
  font-size: 40px;
}

.cfg-empty-state p {
  margin: 0;
  font-size: 13px;
}

/* ---------- Countdown Timer split layout ---------- */
.cfg-countdown {
  display: flex;
  flex: 1;
  min-height: 0;
  overflow: hidden;
}

.cfg-countdown__sidebar {
  width: 280px;
  min-width: 240px;
  padding: 20px 18px;
  display: flex;
  flex-direction: column;
  gap: 18px;
  overflow-y: auto;
  background: var(--bg-dark);
  border-right: 1px solid var(--border);
}

.cfg-countdown__preview {
  flex: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
  background: #0c140e;
}

.cfg-countdown__preview-grid {
  position: absolute;
  inset: 0;
  opacity: 0.06;
  background-image: linear-gradient(var(--border) 1px, transparent 1px),
                     linear-gradient(90deg, var(--border) 1px, transparent 1px);
  background-size: 40px 40px;
}

.cfg-countdown__preview-card {
  position: relative;
  width: 85%;
  max-width: 520px;
  aspect-ratio: 16/9;
  border-radius: 12px;
  border: 1px solid var(--border);
  background: var(--bg-dark);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8px 32px rgba(0,0,0,0.4);
  overflow: hidden;
}

.cfg-countdown__preview-time {
  font-size: clamp(32px, 6vw, 72px);
  font-weight: 900;
  color: #fff;
  font-family: monospace;
  letter-spacing: -2px;
}

.cfg-countdown__preview-msg {
  font-size: clamp(11px, 1.6vw, 18px);
  color: rgba(255,255,255,0.85);
  font-weight: 500;
  margin-top: 8px;
  text-transform: uppercase;
  letter-spacing: 0.05em;
}

.cfg-countdown__preview-badge {
  position: absolute;
  top: 8px;
  left: 8px;
  padding: 3px 8px;
  border-radius: 4px;
  background: rgba(0,0,0,0.6);
  border: 1px solid rgba(255,255,255,0.1);
  font-size: 9px;
  font-weight: 700;
  color: #fff;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.cfg-countdown__duration-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
}

.cfg-duration-input {
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--surface-dark);
  padding: 8px 10px;
  transition: border-color 0.15s;
}

.cfg-duration-input:focus-within {
  border-color: var(--primary);
}

.cfg-duration-input__label {
  display: block;
  font-size: 9px;
  font-weight: 600;
  color: var(--text-muted);
  margin-bottom: 4px;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}

.cfg-duration-input__field {
  width: 100%;
  background: transparent;
  border: none;
  outline: none;
  color: var(--text-primary);
  font-size: 18px;
  font-family: monospace;
}

/* Shared form helpers */
.cfg-field-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}

.cfg-label-upper {
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
}

.cfg-text-input-wrap {
  display: flex;
  align-items: center;
  gap: 8px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--surface-dark);
  padding: 8px 10px;
  transition: border-color 0.15s;
}

.cfg-text-input-wrap:focus-within {
  border-color: var(--primary);
}

.cfg-text-input-icon {
  font-size: 18px;
  color: var(--text-muted);
}

.cfg-text-input {
  flex: 1;
  border: none;
  outline: none;
  background: transparent;
  color: var(--text-primary);
  font-size: 13px;
}

.cfg-text-input::placeholder {
  color: var(--text-muted);
}

.cfg-field-hint {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 10px;
  color: var(--text-muted);
  margin: 0;
}

.cfg-select-wrap {
  position: relative;
}

.cfg-select {
  width: 100%;
  appearance: none;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--surface-dark);
  color: var(--text-primary);
  font-size: 13px;
  padding: 10px 32px 10px 12px;
  outline: none;
  transition: border-color 0.15s;
}

.cfg-select:focus {
  border-color: var(--primary);
}

.cfg-select--lg {
  font-size: 15px;
  padding: 12px 36px 12px 14px;
}

.cfg-select-chevron {
  position: absolute;
  right: 10px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 20px;
  color: var(--text-secondary);
  pointer-events: none;
}

/* ---------- Audio table picker ---------- */
.cfg-audio-picker {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1;
  min-height: 0;
}

.cfg-audio-table-wrap {
  flex: 1;
  overflow-y: auto;
  background: var(--bg-dark);
}

.cfg-audio-table {
  width: 100%;
  border-collapse: collapse;
  text-align: left;
}

.cfg-audio-table thead {
  position: sticky;
  top: 0;
  z-index: 2;
  background: var(--surface-dark);
}

.cfg-audio-table th {
  padding: 10px 14px;
  font-size: 10px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: var(--text-muted);
  border-bottom: 1px solid var(--border);
}

.cfg-audio-table tbody tr {
  cursor: pointer;
  transition: background 0.12s;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}

.cfg-audio-table tbody tr:hover {
  background: var(--surface-hover);
}

.cfg-audio-table tbody tr.is-selected {
  background: rgba(var(--primary-rgb), 0.08);
}

.cfg-audio-table td {
  padding: 12px 14px;
  vertical-align: middle;
}

.cfg-audio-play-btn {
  width: 36px;
  height: 36px;
  border-radius: 50%;
  border: 1px solid var(--border);
  background: var(--surface-dark);
  color: var(--text-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  transition: all 0.12s;
}

.cfg-audio-play-btn:hover {
  background: var(--surface-hover);
  color: var(--text-primary);
}

.cfg-audio-play-btn.is-active {
  background: var(--primary);
  border-color: var(--primary);
  color: #121212;
}

.cfg-audio-track-name {
  font-size: 13px;
  font-weight: 700;
  color: var(--text-primary);
}

.cfg-audio-dur {
  font-family: monospace;
  font-size: 13px;
  color: var(--text-secondary);
  text-align: right;
}

/* ---------- Scene switch configure ---------- */
.cfg-scene {
  padding: 24px 18px;
  display: flex;
  flex-direction: column;
  gap: 20px;
  overflow-y: auto;
  background: var(--bg-dark);
}

.cfg-scene__icon-wrap {
  width: 48px;
  height: 48px;
  border-radius: 12px;
  background: rgba(var(--primary-rgb), 0.12);
  display: flex;
  align-items: center;
  justify-content: center;
}

.cfg-scene__icon-wrap .material-icons {
  font-size: 28px;
  color: var(--primary);
}

.cfg-scene__grid-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}

/* ---------- Template preset grid ---------- */
.cfg-template {
  display: flex;
  flex-direction: column;
  overflow: hidden;
  flex: 1;
  min-height: 0;
}

.cfg-template__grid {
  flex: 1;
  overflow-y: auto;
  padding: 18px;
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
  gap: 14px;
  align-content: start;
  background: var(--bg-dark);
}

.cfg-template-card {
  border-radius: 12px;
  border: 1px solid var(--border);
  overflow: hidden;
  background: var(--surface-dark);
  cursor: pointer;
  transition: border-color 0.15s, background 0.15s;
}

.cfg-template-card:hover {
  border-color: var(--text-muted);
  background: var(--surface-hover);
}

.cfg-template-card__preview {
  height: 100px;
  background: var(--bg-dark);
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}

.cfg-template-card__preview .material-icons {
  font-size: 42px;
  color: var(--text-muted);
  opacity: 0.35;
}

.cfg-template-card__body {
  padding: 14px;
}

.cfg-template-card__body h4 {
  margin: 0 0 4px;
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
}

.cfg-template-card__body p {
  margin: 0;
  font-size: 11px;
  color: var(--text-secondary);
}

.cfg-template-card__meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12px;
  padding-top: 10px;
  border-top: 1px solid var(--border);
}

.cfg-template-card__time {
  font-size: 11px;
  font-family: monospace;
  color: var(--text-muted);
}

.cfg-template-card__tag {
  font-size: 9px;
  font-weight: 700;
  text-transform: uppercase;
  padding: 3px 8px;
  border-radius: 4px;
  background: rgba(var(--primary-rgb), 0.12);
  color: var(--primary);
}

.cfg-template-card--add {
  border-style: dashed;
  display: flex;
  align-items: center;
  justify-content: center;
  min-height: 200px;
}

.cfg-template-card--add:hover {
  border-color: var(--primary);
}

.cfg-template-card__add-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8px;
  text-align: center;
  padding: 16px;
  color: var(--text-muted);
  transition: color 0.15s;
}

.cfg-template-card--add:hover .cfg-template-card__add-inner {
  color: var(--primary);
}

.cfg-template-card__add-inner .material-icons {
  font-size: 36px;
}

.cfg-template-card__add-inner h4 {
  margin: 0;
  font-size: 14px;
  font-weight: 700;
  color: var(--text-primary);
}

.cfg-template-card__add-inner p {
  margin: 0;
  font-size: 11px;
  color: var(--text-secondary);
}

/* ---------- Responsive for configure forms ---------- */
@media (max-width: 900px) {
  .cfg-countdown {
    flex-direction: column;
  }

  .cfg-countdown__sidebar {
    width: 100%;
    min-width: 0;
    border-right: none;
    border-bottom: 1px solid var(--border);
  }

  .cfg-media-grid--video {
    grid-template-columns: repeat(auto-fill, minmax(130px, 1fr));
  }

  .cfg-media-grid--image {
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
  }

  .cfg-scene__grid-row {
    grid-template-columns: 1fr;
  }

  .cfg-template__grid {
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  }
}

/* ───────────────────────────────────────────────────────
   File Upload Drop Zone
   ─────────────────────────────────────────────────────── */
.cfg-upload-zone {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8px;
  padding: 20px 16px;
  margin: 12px 18px 0;
  border: 2px dashed var(--border);
  border-radius: 10px;
  background: var(--surface-dark);
  color: var(--text-muted);
  transition: border-color 0.2s, background 0.2s, color 0.2s;
  cursor: pointer;
}

.cfg-upload-zone:hover {
  border-color: var(--text-muted);
  background: var(--surface-hover);
}

.cfg-upload-zone.is-dragging {
  border-color: var(--primary);
  background: rgba(var(--primary-rgb), 0.06);
  color: var(--primary);
}

.cfg-upload-zone .material-icons {
  font-size: 32px;
}

.cfg-upload-zone p {
  margin: 0;
  font-size: 13px;
  font-weight: 500;
}

.cfg-upload-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 7px 16px;
  border-radius: 6px;
  border: 1px solid var(--primary);
  background: var(--primary);
  color: #121212;
  font-size: 12px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s;
}

.cfg-upload-btn:hover {
  background: var(--primary-hover);
}

.cfg-upload-hint {
  font-size: 10px;
  color: var(--text-muted);
  letter-spacing: 0.02em;
}

/* ───────────────────────────────────────────────────────
   Go Live Confirmation Modal
   ─────────────────────────────────────────────────────── */
.ps-confirm-modal {
  width: min(420px, 92vw);
  border-radius: 14px;
  border: 1px solid var(--border);
  background: var(--surface-raised);
  padding: 28px 24px 22px;
  display: flex;
  flex-direction: column;
  align-items: center;
  text-align: center;
  gap: 12px;
  box-shadow: 0 28px 70px rgba(0, 0, 0, 0.5);
}

.ps-confirm-icon {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(231, 72, 86, 0.12);
  border: 1px solid rgba(231, 72, 86, 0.25);
}

.ps-confirm-icon .material-icons {
  font-size: 28px;
  color: var(--error, #e74856);
}

.ps-confirm-title {
  margin: 0;
  font-size: 20px;
  font-weight: 800;
  color: var(--text-primary);
}

.ps-confirm-text {
  margin: 0;
  font-size: 13px;
  line-height: 1.55;
  color: var(--text-secondary);
  max-width: 340px;
}

.ps-confirm-actions {
  display: flex;
  gap: 10px;
  width: 100%;
  margin-top: 8px;
}

.ps-confirm-cancel,
.ps-confirm-go {
  flex: 1;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  padding: 10px 16px;
  border-radius: 8px;
  font-size: 13px;
  font-weight: 700;
  cursor: pointer;
  transition: background 0.15s, border-color 0.15s;
}

.ps-confirm-cancel {
  border: 1px solid var(--border);
  background: var(--surface-hover);
  color: var(--text-secondary);
}

.ps-confirm-cancel:hover {
  border-color: var(--text-muted);
  color: var(--text-primary);
}

.ps-confirm-go {
  border: 1px solid var(--error, #e74856);
  background: var(--error, #e74856);
  color: #fff;
}

.ps-confirm-go:hover {
  background: #d13945;
  border-color: #d13945;
}

.ps-confirm-go .material-icons {
  font-size: 18px;
}
